{
  "name": "whatsapp-gateway",
  "version": "1.0.0",
  "description": "WhatsApp Gateway Node.js Application",
  "main": "src/server.js",
  "author": "Thathsara Bandara",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --watchAll --verbose --maxWorkers=1",
    "test:ci": "jest --ci --coverage --maxWorkers=1",
    "test:coverage": "jest --coverage --maxWorkers=1",
    "lint": "eslint src --ext .js --max-warnings 0",
    "lint:fix": "eslint src --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "lint:report": "eslint src --ext .js --format json --output-file eslint-report.json || true",
    "build": "echo 'Build process completed'",
    "validate": "npm run lint && npm run test:coverage",
    "register:phone": "node src/cli/registerPhone.js",
    "db:init": "node src/config/database-init.js",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:seed": "sequelize-cli db:seed:all"
  },
  "keywords": [
    "whatsapp",
    "gateway",
    "nodejs",
    "api",
    "messaging"
  ],
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "mysql2": "^3.18.1",
    "qrcode-terminal": "^0.12.0",
    "redis": "^5.11.0",
    "sequelize": "^6.37.7",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.10.5",
    "eslint": "^8.53.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jest": "^27.6.0",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.2",
    "nodemon": "^3.0.2",
    "prettier": "^3.8.1",
    "sequelize-cli": "^6.6.5",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1"
  }
}
